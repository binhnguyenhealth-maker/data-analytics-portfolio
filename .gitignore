# Synthetic outputs (regenerated by shared/validation/regenerate_all.py)
projects/*/data/synthetic/**
shared/synthetic/*.csv
**/.locks/

# Cooperative staging lock (not a tracked artifact)
STAGING_LOCK.md
LICENSE_PENDING.md

# Python caches
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
validation/*.log

# Editor / OS noise
.DS_Store
*.swp
*~

# Native artifacts are denied by default. Exact release directories below are
# re-included; the structure validator rejects any other binary placement.
*.twbx
*.twb
*.hyper
*.pdf
*.png
*.jpeg
*.jpg
*.xlsx
*.docx
*.tab
*.zip
*.tar
*.gz

!projects/*/tableau/
!projects/*/tableau/*.twbx
!projects/*/images/
!projects/*/images/dashboard-preview.jpeg
